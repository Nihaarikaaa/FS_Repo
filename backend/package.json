{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "nodemon index.js",
    "test": "jest --testTimeout=10000 --verbose --ci --testResultsProcessor=\"jest-junit\"",
    "sample_tests": "jest --forceExit --testTimeout=10000 --verbose --ci --testResultsProcessor=\"jest-junit\" -- sample.test.js",
    "main_tests": "jest --forceExit --testTimeout=10000 --verbose --ci --testResultsProcessor=\"jest-junit\" -- main.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "2.8.5",
    "dotenv": "16.0.1",
    "express": "4.18.1",
    "http-errors": "2.0.0",
    "jest": "29.0.1",
    "jest-junit": "14.0.1",
    "mongodb": "4.9.0",
    "mongoose": "6.5.2",
    "morgan": "1.10.0",
    "multer": "1.4.5-lts.1",
    "nodemon": "2.0.19",
    "supertest": "6.2.4",
    "uuid": "8.3.2"
  },
  "jest-junit": {
    "suiteName": "jest tests",
    "outputDirectory": ".",
    "outputName": "xunittest-report.xml",
    "uniqueOutputName": "false",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}",
    "ancestorSeparator": " › ",
    "usePathForSuiteName": "true"
  }
